{
  "name": "react-native-fluid-swipe-list",
  "version": "1.0.0",
  "description": "High-performance, fully customizable React Native swipeable list items with native-feeling gestures and animations",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
