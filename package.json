  "keywords": [
    "react-native",
    "swipe",
    "list",
    "gesture",
    "animation",
    "reanimated",
    "flashlist",
    "flatlist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VatsalPatadiya/react-native-swipe-actions.git"
  },
  "author": "Vatsal Patadiya",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/VatsalPatadiya/react-native-swipe-actions/issues"
  },
  "homepage": "https://github.com/VatsalPatadiya/react-native-swipe-actions#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "react-native-builder-bob": "^0.23.0",
    "react-native-gesture-handler": "^2.12.0",
    "react-native-reanimated": "^3.5.0",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
